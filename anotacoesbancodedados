1.

SELECT nome_curso, preco_curso
FROM tb_cursos
WHERE preco_curso >= 1000
ORDER BY preco_curso ASC;

2.

SELECT nome_aluno, idade_aluno, email_aluno
FROM tb_alunos
WHERE email_aluno IS NULL
ORDER BY nome_aluno ASC;

3.

SELECT nome_professor, salario_professor
FROM tb_professores
WHERE salario_professor >= 5000 AND salario_professor <= 6000
ORDER BY nome_professor ASC;

4. 

SELECT 
COUNT(cod_professor) as total_professores,
AVG(salario_professor) as media_salarial
FROM tb_professores;

5.

SELECT cod_regiao,
COUNT(cod_professor) as total_professores,
AVG(salario_professor) as media_salarial
FROM tb_professores
GROUP BY cod_regiao;

6.

SELECT SUM(carga_horaria_curso) AS carga_horaria_total
FROM tb_cursos;

7.

SELECT cod_cidade, COUNT(cod_aluno) as total_alunos
FROM tb_alunos
GROUP BY cod_cidade;

8.

SELECT cod_cidade,
COUNT(cod_aluno) AS total_alunos
FROM tb_alunos
GROUP BY cod_cidade
HAVING COUNT(cod_aluno) > 1;

9.

SELECT a.nome_aluno, c.nome_cidade
FROM tb_alunos a
INNER JOIN tb_cidades c ON a.cod_cidade = c.cod_cidade
ORDER BY c.nome_cidade ASC;

10.

SELECT c.nome_cidade, 
COUNT(a.cod_aluno) as total_alunos
FROM tb_alunos a
INNER JOIN tb_cidades c ON a.cod_cidade = c.cod_cidade
GROUP BY a.cod_cidade
HAVING COUNT(a.cod_aluno) > 1;

11.

SELECT c.nome_cidade, e.sigla_estado
FROM tb_cidades c
INNER JOIN tb_estados e ON c.cod_estado = e.cod_estado
GROUP BY c.nome_cidade;

12.

SELECT a.nome_aluno, c.nome_curso, m.nota_matricula
FROM tb_alunos a
INNER JOIN tb_matriculas m ON a.cod_aluno = m.cod_aluno
INNER JOIN tb_cursos c ON m.cod_curso = c.cod_curso;

--------------------------------------------------------------------

SELECT a.nome_aluno, c.nome_curso, m.nota_matricula
FROM tb_alunos a
INNER JOIN tb_matriculas m ON a.cod_aluno = m.cod_aluno
INNER JOIN tb_cursos c ON m.cod_curso = c.cod_curso
WHERE m.nota_matricula IS NOT NULL;

13.

SELECT a.nome_aluno, c.nome_curso, p.nome_professor
FROM tb_matriculas m
INNER JOIN tb_professores p ON m.cod_professor = p.cod_professor
INNER JOIN tb_alunos a ON m.cod_aluno = a.cod_aluno
INNER JOIN tb_cursos c ON m.cod_curso = a.cod_aluno;

14.

SELECT a.nome_aluno, c.nome_curso, p.nome_professor
FROM tb_matriculas m
INNER JOIN tb_alunos a ON m.cod_aluno = a.cod_aluno
INNER JOIN tb_cursos c ON m.cod_curso = c.cod_curso
INNER JOIN tb_professores p ON m.cod_professor = p.cod_professor
WHERE a.nome_aluno = 'Carla Oliveira';

15.

SELECT nome_aluno, idade_aluno
FROM tb_alunos
WHERE idade_aluno > (SELECT AVG(idade_aluno) FROM tb_alunos);

16.

SELECT c.nome_curso, c.preco_curso
FROM tb_cursos c
WHERE c.preco_curso > (SELECT preco_curso FROM tb_cursos WHERE nome_curso = 'Programação Web');

17.

SELECT a.nome_aluno, m.nota_matricula
FROM tb_matriculas m
INNER JOIN tb_alunos a ON m.cod_aluno = a.cod_aluno
WHERE m.nota_matricula = (SELECT MAX(nota_matricula) FROM tb_matriculas);

